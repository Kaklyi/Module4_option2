Pseudocode
------------------------------------------

START

// Declare variables
DECLARE sum = 0
DECLARE max = NEGATIVE_INFINITY
DECLARE min = POSITIVE_INFINITY
DECLARE grade
DECLARE average

// Loop to collect 10 grades
FOR i FROM 1 TO 10

    DISPLAY "Enter grade #" + i
    INPUT grade

    // Validate input
    WHILE input is not a number
        DISPLAY "Error: please enter a valid number"
        INPUT grade
    END WHILE

    // Add grade to total
    SET sum = sum + grade

    // Update maximum grade
    IF grade > max THEN
        SET max = grade
    END IF

    // Update minimum grade
    IF grade < min THEN
        SET min = grade
    END IF

END FOR

// Calculate average
SET average = sum / 10

// Display results
DISPLAY average
DISPLAY max
DISPLAY min

END
